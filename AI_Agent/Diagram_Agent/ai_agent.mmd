flowchart TB
    %% Core RPC Communication Layer
    subgraph rpc_layer ["RPC Communication"]
        game_client["GameRpcClient"]
        socket_handler["Socket Handler"]
        json_protocol["JSON Protocol Parser"]
    end

    %% Game State & Data Processing
    subgraph game_state ["Game State"]
        state_manager[("State Manager")]
        unit_tracker["Unit Tracker"]
        player_monitor["Player Monitor"]
    end

    %% AI Planning & Decision Making
    subgraph ai_planning ["AI Planning System"]
        local_llm["Local LLM Planner"]
        prompt_cache["Prompt Cache"]
        state_compressor["State Compressor"]
        command_library["Command Library"]
    end

    %% AI Control Loop
    subgraph local_controller ["AI Control Loop"]
        local_ai_controller["LocalAiController"]
        preprocess["State Preprocessor"]
        snapshot_builder["LLM Snapshot Builder"]
        command_sanitizer["Command Sanitizer"]
        fallback["Fallback Behavior"]
    end

    %% Game Command Execution
    subgraph command_exec ["Command Execution"]
        message_creator["Message Creator"]
        unit_selector["Unit Selector"]
        action_executor["Action Executor"]
    end

    %% External Services
    subgraph external_services ["External Services"]
        ollama_endpoint["Ollama LLM Endpoint"]
        game_server["C&C Generals Server"]
    end

    %% Logging & Monitoring
    subgraph logging_system ["Logging & Diagnostics"]
        rpc_logger["RPC Communication Log"]
        llm_interaction_log["LLM Interaction Log"]
        game_logger["Game Logger"]
    end

    %% RPC Layer connections
    game_client --> socket_handler
    socket_handler --> json_protocol

    %% RPC to Game State connections
    json_protocol --> state_manager
    state_manager --> unit_tracker
    state_manager --> player_monitor

    %% Controller loop connections
    game_client --> local_ai_controller
    local_ai_controller --> preprocess
    preprocess --> snapshot_builder
    snapshot_builder --> state_compressor
    snapshot_builder --> local_llm
    local_llm --> command_sanitizer
    command_sanitizer --> action_executor
    local_ai_controller --> action_executor
    local_ai_controller --> command_library

    %% Game State to AI Planning
    state_manager --> state_compressor
    state_compressor --> prompt_cache
    prompt_cache --> local_llm
    command_library --- local_llm

    %% AI Planning to Command Execution
    local_llm --> message_creator
    message_creator --> unit_selector
    unit_selector --> action_executor

    %% External Service connections
    local_llm -.-> ollama_endpoint
    game_client -.-> game_server
    action_executor -.-> game_server

    %% Logging connections
    game_client -.-> rpc_logger
    local_llm -.-> llm_interaction_log
    state_manager -.-> game_logger

    %% Styling
    style state_manager fill:#f9f,stroke:#333,stroke-width:2px
    style local_llm fill:#bbf,stroke:#333
    style game_server fill:#fbb,stroke:#333